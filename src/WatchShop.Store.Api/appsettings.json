{
  "Database": {
    "Server": "localhost",
    "Port": 3306,
    "Database": "dotnet_all_in1",
    "User": "dotnet_all_in2",
    "Password": "dotnet_all_in3"
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379",
    "DefaultExpirationMinutes": 30
  },
  "Order": {
    "PaymentTimeoutMinutes": 30
  },
  "StoreJwt": {
    "Issuer": "WatchShop.Store",
    "Audience": "WatchShop.Store.Client",
    "SecretKey": "store-dev-only-change-in-production-min-32-chars!",
    "ExpirationMinutes": 720
  },
  "Messaging": {
    "UseCap": false,
    "RabbitMqHost": "localhost",
    "RabbitMqPort": 5672,
    "RabbitMqUser": "guest",
    "RabbitMqPassword": "guest",
    "DefaultGroup": "watchshop"
  },
  "Payment": {
    "WebhookSecret": "dev-webhook-secret"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
