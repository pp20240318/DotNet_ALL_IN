{
  "Database": {
    "Server": "localhost",
    "Port": 3306,
    "Database": "dotnet_all_in1",
    "User": "dotnet_all_in2",
    "Password": "dotnet_all_in3"
  },
  "Jwt": {
    "Issuer": "WatchShop.Admin",
    "Audience": "WatchShop.Admin.Client",
    "SecretKey": "dev-only-change-in-production-min-32-chars!!",
    "ExpirationMinutes": 120
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379",
    "DefaultExpirationMinutes": 30
  },
  "Order": {
    "PaymentTimeoutMinutes": 30
  },
  "StoreJwt": {
    "Issuer": "WatchShop.Store",
    "Audience": "WatchShop.Store.Client",
    "SecretKey": "store-dev-only-change-in-production-min-32-chars!",
    "ExpirationMinutes": 720
  },
  "Messaging": {
    "UseCap": false,
    "RabbitMqHost": "localhost",
    "RabbitMqPort": 5672,
    "RabbitMqUser": "guest",
    "RabbitMqPassword": "guest",
    "DefaultGroup": "watchshop"
  },
  "FileStorage": {
    "RootPath": "wwwroot/uploads",
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp", ".gif" ]
  },
  "Payment": {
    "WebhookSecret": "dev-webhook-secret"
  },
  "Minio": {
    "Enabled": false,
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "watchshop",
    "UseSsl": false,
    "PublicBaseUrl": "http://localhost:9000"
  },
  "Elasticsearch": {
    "Enabled": false,
    "Uri": "http://localhost:9200",
    "IndexName": "watchshop-catalog"
  },
  "Hangfire": {
    "Enabled": true,
    "DashboardPath": "/hangfire"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
