{
  "Database": {
    "Server": "mysql",
    "Port": 3306,
    "Database": "dotnet_all_in1",
    "User": "dotnet_all_in2",
    "Password": "dotnet_all_in3"
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "redis:6379"
  },
  "Messaging": {
    "UseCap": true,
    "RabbitMqHost": "rabbitmq",
    "RabbitMqPort": 5672,
    "RabbitMqUser": "guest",
    "RabbitMqPassword": "guest",
    "DefaultGroup": "watchshop"
  },
  "Minio": {
    "Enabled": true,
    "Endpoint": "minio:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "watchshop",
    "UseSsl": false,
    "PublicBaseUrl": "http://localhost:9000"
  },
  "Elasticsearch": {
    "Enabled": true,
    "Uri": "http://elasticsearch:9200",
    "IndexName": "watchshop-catalog"
  },
  "Hangfire": {
    "Enabled": true,
    "DashboardPath": "/hangfire"
  },
  "Payment": {
    "WebhookSecret": "prod-webhook-secret-change-me"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
